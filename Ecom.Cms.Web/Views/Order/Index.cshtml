@using Ecom.Cms.Web.Shared.Models.Order.ViewModel.Order
@model List<OrderSummaryViewModel>

@{
    ViewData["Title"] = "Danh sách đơn hàng";
}

<div class="container-fluid py-4">
    <div class="card shadow-sm border-0">
        <div class="card-header bg-white py-3">
            <h5 class="mb-0 fw-bold"><i class="bi bi-list-ul me-2"></i>@ViewData["Title"]</h5>
        </div>
        <div class="card-body p-0">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-4">Mã đơn</th>
                        <th>Ngày tạo</th>
                        <th>Sản phẩm</th>
                        <th>Tổng tiền</th>
                        <th>Trạng thái</th>
                        <th class="text-end pe-4">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4 fw-bold">@Html.DisplayFor(m => item.OrderCode)</td>
                                <td>@item.CreatedAt?.ToString("dd/MM/yyyy HH:mm")</td>
                                <td>
                                    <span class="badge bg-light text-dark border">@item.TotalItems món</span>
                                </td>
                                <td class="text-danger fw-bold">
                                    @* 1. Chỉ comment dòng quan trọng: Dùng string format hiển thị tiền tệ *@
                                    @string.Format("{0:N0} {1}", item.TotalAmount, item.Currency)
                                </td>
                                <td>
                                    <span class="badge @(item.StatusName == "Success" ? "bg-success" : "bg-warning")">
                                        @item.StatusName
                                    </span>
                                </td>
                                <td class="text-end pe-4">
                                    @* 2. Chỉ comment dòng quan trọng: Dùng Tag Helper để tạo link chi tiết *@
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">
                                        <i class="bi bi-search"></i> Xem
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>